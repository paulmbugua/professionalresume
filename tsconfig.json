{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": "./",
    "paths": {
      "@shared/*": [
        "./packages/shared/*"
      ]
    }
  },
  "include": [
    "apps",
    "packages"
  ]
}
