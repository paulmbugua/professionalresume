{
  "name": "mytutorapp",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "nohoist": [
      "expo",
      "expo/**",
      "react-native",
      "react-native/**",
      "@expo/metro-config",
      "@expo/metro-config/**",
      "@react-native-async-storage/async-storage",
      "@react-native-async-storage/async-storage/**",
      "@react-native-community/cli-platform-android",
      "@react-native-community/cli-platform-android/**",
      "@react-native-google-signin/google-signin",
      "@react-native-google-signin/google-signin/**",
      "@react-native-picker/picker",
      "@react-native-picker/picker/**",
      "expo-av",
      "expo-av/**",
      "expo-dev-client",
      "expo-dev-client/**",
      "expo-document-picker",
      "expo-document-picker/**",
      "expo-linear-gradient",
      "expo-linear-gradient/**",
      "expo-location",
      "expo-location/**",
      "expo-router",
      "expo-router/**",
      "expo-splash-screen",
      "expo-splash-screen/**",
      "expo-asset",
      "expo-asset/**",
      "expo-system-ui",
      "expo-system-ui/**",
      "react-native-config",
      "react-native-config/**",
      "react-native-gesture-handler",
      "react-native-gesture-handler/**",
      "react-native-safe-area-context",
      "react-native-safe-area-context/**",
      "react-native-screens",
      "react-native-screens/**",
      "react-native-svg",
      "react-native-svg/**",
      "react-native-vector-icons",
      "react-native-vector-icons/**",
      "twrnc",
      "twrnc/**",
      "expo-cli",
      "expo-cli/**"
    ]
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "install:natives": "node scripts/check-native-modules.js",
    "format": "prettier . --write",
    "reset:expo": "node reset-health.js",
    "reset:expo:fast": "node reset-health.js --fast",
    "health:android": "node android-health.js",
    "health:android:fix": "node android-health.js --fix",
    "doctor:expo": "node reset-health.js --doctor-only",
    "format:check": "prettier . --check",
    "dev:web": "yarn workspace @mytutorapp/web dev",
    "dev:mobile": "yarn workspace @mytutorapp/mobile dev",
    "android": "yarn workspace @mytutorapp/mobile android",
    "ios": "yarn workspace @mytutorapp/mobile ios",
    "eas:build:dev": "yarn workspace @mytutorapp/mobile eas build --platform android --profile development",
    "eas:build:preview": "yarn workspace @mytutorapp/mobile eas build --platform android --profile preview",
    "eas:build:prod": "yarn workspace @mytutorapp/mobile eas build --platform android --profile production",
    "eas:submit:prod": "yarn workspace @mytutorapp/mobile eas submit --platform android --profile production"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "eas-cli": "^16.3.3",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.4.21",
    "prettier": "^3.5.3",
    "rimraf": "3.0.2",
    "tailwindcss": "^3.3.2",
    "turbo": "^2.4.4",
    "typescript": "^5.4.5"
  },
  "resolutions": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "esbuild": "0.17.19"
  },
  "dependencies": {}
}
