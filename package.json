{
  "name": "mytutorapp",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "main": "apps/mobile/index.tsx",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "start": "expo start",
    "start:web": "expo start --web --config apps/web/app.json",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "preview:web": "vite preview --config apps/web/vite.config.ts",
    "start:mobile": "expo start --config apps/mobile/app.config.js",
    "android": "expo run:android --config apps/mobile/app.config.js",
    "ios": "expo run:ios --config apps/mobile/app.config.js",
    "build:android:dev": "eas build --platform android --profile development --project-dir apps/mobile",
    "build:android:prod": "eas build --platform android --profile production --project-dir apps/mobile",
    "build:ios:dev": "eas build --platform ios --profile development --project-dir apps/mobile",
    "build:ios:prod": "eas build --platform ios --profile production --project-dir apps/mobile",
    "lint:watch": "onchange \"**/*.{ts,tsx,js,jsx}\" -- yarn lint"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-native-fontawesome": "^0.3.2",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-native-picker/picker": "^2.11.0",
    "@react-navigation/native": "^7.0.15",
    "@react-navigation/stack": "^7.1.2",
    "axios": "^1.8.3",
    "dotenv": "^16.4.7",
    "esbuild": "0.17.19",
    "expo": "^52.0.44",
    "expo-av": "~15.0.2",
    "expo-build-properties": "~0.13.2",
    "expo-dev-client": "~5.0.14",
    "expo-document-picker": "~13.0.3",
    "expo-linear-gradient": "^14.0.2",
    "expo-modules-core": "^2.2.3",
    "firebase": "^11.6.0",
    "nativewind": "^4.1.23",
    "postcss": "^8.4.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.76.9",
    "react-native-config": "^1.5.5",
    "react-native-dev-menu": "^4.1.1",
    "react-native-gesture-handler": "^2.25.0",
    "react-native-reanimated": "^3.17.1",
    "react-native-safe-area-context": "^5.3.0",
    "react-native-screens": "^4.9.2",
    "react-native-svg": "^15.11.2",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.19.13",
    "react-router": "^6.16.0",
    "react-router-dom": "^6.16.0",
    "react-toastify": "^11.0.5",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.3.2",
    "twrnc": "^4.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.2.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^22.13.14",
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.0.4",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "autoprefixer": "^10.4.21",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^12.0.11",
    "cross-env": "^7.0.3",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "onchange": "^7.1.0",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript-eslint": "^7.6.0",
    "vite": "^4.5.9"
  }
}
