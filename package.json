{
  "name": "mytutorapp",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier . --write",
    "reset:expo": "node reset-health.js",
    "reset:expo:fast": "node reset-health.js --fast",
    "health:android": "node android-health.js",
     "health:android:fix": "node android-health.js --fix",
    "doctor:expo": "node reset-health.js --doctor-only",
    "format:check": "prettier . --check",
    "dev:web": "yarn workspace @mytutorapp/web dev",
    "dev:mobile": "yarn workspace @mytutorapp/mobile dev",
    "android": "yarn workspace @mytutorapp/mobile android",
    "ios": "yarn workspace @mytutorapp/mobile ios"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "eas-cli": "^16.3.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.4.21",
    "prettier": "^3.5.3",
    "rimraf": "3.0.2",
    "tailwindcss": "^3.3.2",
    "turbo": "^2.4.4",
    "typescript": "^5.4.5"
  },
  "resolutions": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "esbuild": "0.17.19"
  },
  "dependencies": {
    "expo": "~50.0.17"
  }
}
