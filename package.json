{
   "name": "mytutorapp",
   "version": "1.0.0",
   "private": true,
   "packageManager": "yarn@4.9.1",
   "workspaces": [
      "apps/*",
      "packages/*"
   ],
   "nohoist": [
      "**/react-native",
      "**/react-native/**",
      "**/expo",
      "**/expo/**",
      "**/@expo/metro-config",
      "**/@expo/metro-config/**"
   ],
   "scripts": {
      "dev": "turbo run dev",
      "build:all": "yarn workspaces run build",
      "start": "yarn workspace @mytutorapp/backend start",
      "start:backend": "yarn workspace @mytutorapp/backend start",
      "start:web": "serve -s apps/web/dist",
      "start:mobile": "serve -s apps/mobile/web-build",
      "build": "turbo run build --filter=@mytutorapp/backend... --filter=@mytutorapp/web...",
      "lint": "turbo run lint",
      "lint:fix": "turbo run lint -- --fix",
      "test": "turbo run test",
      "format": "prettier . --write",
      "format:check": "prettier . --check",
      "install:natives": "node scripts/check-native-modules.js",
      "reset:expo": "node reset-health.js",
      "health:android": "node android-health.js",
      "dev:mobile": "yarn workspace @mytutorapp/mobile dev",
      "android": "yarn workspace @mytutorapp/mobile android",
      "ios": "yarn workspace @mytutorapp/mobile ios",
      "eas:build:dev": "yarn workspace @mytutorapp/mobile eas build --platform android --profile development",
      "eas:build:preview": "yarn workspace @mytutorapp/mobile eas build --platform android --profile preview",
      "eas:build:prod": "yarn workspace @mytutorapp/mobile eas build --platform android --profile production",
      "eas:submit:prod": "yarn workspace @mytutorapp/mobile eas submit --platform android --profile production"
   },
   "devDependencies": {
      "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
      "@babel/plugin-proposal-optional-chaining": "^7.21.0",
      "@types/lodash.debounce": "^4.0.9",
      "@types/react-native-vector-icons": "6.4.18",
      "@typescript-eslint/eslint-plugin": "^8.31.1",
      "@typescript-eslint/parser": "^8.31.1",
      "autoprefixer": "^10.4.21",
      "babel-plugin-transform-remove-console": "^6.9.4",
      "eslint": "^8",
      "eslint-config-prettier": "^10.1.1",
      "eslint-import-resolver-typescript": "^4.3.4",
      "eslint-plugin-import": "^2.31.0",
      "eslint-plugin-prettier": "^5.2.5",
      "eslint-plugin-react": "^7.37.4",
      "eslint-plugin-react-hooks": "^5.2.0",
      "postcss": "^8.4.21",
      "prettier": "^3.5.3",
      "rimraf": "3.0.2",
      "serve": "^14.2.4",
      "tailwindcss": "^3.3.2",
      "turbo": "^2.4.4",
      "typescript": "^5.4.5"
   },
   "dependencies": {
      "expo-constants": "~15.4.6",
      "expo-linking": "~6.2.2",
      "expo-status-bar": "~1.11.1",
      "firebase-admin": "^13.5.0",
      "moti": "^0.30.0",
      "react-native-reanimated": "~3.6.2"
   },
   "resolutions": {
      "react": "18.2.0",
      "react-dom": "18.2.0"
   }
}
