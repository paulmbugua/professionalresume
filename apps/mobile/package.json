{
  "name": "@mytutorapp/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.tsx",
  "scripts": {
    "dev": "expo start",
    "build": "expo export",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "doctor": "expo-doctor"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/cli-platform-android": "^18.0.0",
    "@react-native-google-signin/google-signin": "13.2.0",
    "@react-navigation/native": "7.0.15",
    "@react-navigation/stack": "7.1.2",
    "expo": "~50.0.0-preview.6",
    "expo-av": "~13.10.6",
    "expo-build-properties": "~0.11.1",
    "expo-dev-client": "~3.3.12",
    "expo-document-picker": "~11.10.1",
    "expo-linear-gradient": "~12.7.2",
    "expo-location": "~16.5.5",
    "expo-router": "~3.4.10",
    "expo-splash-screen": "~0.26.5",
    "expo-system-ui": "~2.9.4",
    "firebase": "11.6.0",
    "nativewind": "4.1.23",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-config": "1.5.5",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-reanimated": "~3.6.2",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-vector-icons": "10.2.0",
    "twrnc": "4.6.1"
  },
  "devDependencies": {
    "@babel/core": "7.24.0",
    "@testing-library/react-native": "12.4.5",
    "@types/jest": "29.5.12",
    "babel-plugin-module-resolver": "5.0.2",
    "babel-preset-expo": "~10.0.0",
    "eas-cli": "^16.3.2",
    "jest": "29.7.0",
    "jest-expo": "~50.0.0",
    "ts-jest": "29.1.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|twrnc)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@mytutorapp/shared/(.*)$": "<rootDir>/../../packages/shared/$1"
    }
  }
}
