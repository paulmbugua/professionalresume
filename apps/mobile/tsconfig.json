{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "target": "esnext",
    "lib": ["esnext"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@mytutorapp/shared": ["../../packages/shared/index.ts", "../../packages/shared/index.d.ts"],
      "@mytutorapp/shared/*": ["../../packages/shared/*"],
      "@mytutorapp/shared/types": ["../../packages/shared/types/index.ts", "../../packages/shared/types/index.d.ts"]
    },
    "typeRoots": ["../../node_modules/@types"]
  },
  "include": [
    "src/**/*",
    "index.tsx",
    "images.d.ts",
    "types/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "nativewind-env.d.ts",
    "declarations.d.ts",
    "src/**/*.d.ts",
    "utils"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios",
    "web-build",
    "**/__mocks__/**",
    "**/__fixtures__/**"
  ]
}
