{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "dom",
      "esnext"
    ],
    "jsx": "preserve",
    "types": [
      "react",
      "react-dom",
      "node",
      "next"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      // point to the flat shared folder
      "@shared": [
        "../../packages/shared"
      ],
      "@shared/*": [
        "../../packages/shared/*"
      ],
      "@cvpro/shared": [
        "../../packages/shared/index.ts",
        "../../packages/shared/index.d.ts"
      ],
      "@cvpro/shared/*": [
        "../../packages/shared/*"
      ],
      "@cvpro/shared/types": [
        "../../packages/shared/types/index.ts",
        "../../packages/shared/types/index.d.ts"
      ]
    },
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "src",
    "*.ts",
    "*.tsx",
    "../../packages/shared",
    ".next/types/**/*.ts"
, "eslint.config.mjs"  ],
  "exclude": [
    "node_modules"
  ]
}
