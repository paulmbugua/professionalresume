{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "esnext"],
    "jsx": "react-jsx",
    "types": ["react", "react-dom", "vite/client"],
    "baseUrl": ".",    
    "paths": {
       "@/*": ["src/*"], 
      "@shared": ["../../packages/shared/src"],
      "@shared/*": ["../../packages/shared/src/*"],
      "@mytutorapp/shared": ["../../packages/shared/src"],
      "@mytutorapp/shared/*": ["../../packages/shared/src/*"]
      
    }
  },
  "include": [
    "src",
    "*.ts",
    "*.tsx",
    "../../packages/shared/src"
  ]
}
