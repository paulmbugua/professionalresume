{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "jsx": "react",
    "baseUrl": ".",
    "lib": ["dom", "dom.iterable", "esnext"],
    "paths": {
      "@shared/*": ["./*"],
      "@cvpro/shared": ["./index.ts", "./index.d.ts"],
      "@cvpro/shared/*": ["./*"],
      "@cvpro/shared/types": ["./types/index.ts", "./types/index.d.ts"]
    },
    "types": ["node"],
    "outDir": "dist"
  },
  "include": [
    "index.ts",
    "api/**/*",
    "hooks/**/*",
    "utils/**/*",
    "context/**/*",
    "types/**/*",
    "scripts/**/*"
  ]
}
