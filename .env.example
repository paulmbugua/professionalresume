# CVPro dedicated M-Pesa callback URL.
# Precedence used by backend:
#   1) MPESA_CVPRO_CALLBACK_URL
#   2) CVPRO_MPESA_CALLBACK_URL (legacy compatibility)
#   3) MPESA_CALLBACK_URL (generic fallback)
#   4) CALLBACK_URL (legacy generic fallback)
#
# IMPORTANT: Daraja callback URLs must be publicly reachable (not localhost).
# For local development, use a public tunnel URL (ngrok / Cloudflare Tunnel).
MPESA_CVPRO_CALLBACK_URL=https://your-public-domain/api/cv/payments/mpesa/callback

# Optional generic STK callback fallback (shared flows)
MPESA_CALLBACK_URL=https://your-public-domain/api/mpesa/callback
